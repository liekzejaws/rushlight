<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/list_background_color">

    <!-- Toolbar with history button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:titleTextColor="?attr/app_bar_primary_item_color" />

        <ImageButton
            android:id="@+id/history_button"
            style="@style/Widget.AppCompat.ActionButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/p2p_share_transfer_history"
            app:srcCompat="@drawable/ic_action_history"
            app:tint="?attr/app_bar_primary_item_color" />

    </FrameLayout>

    <!-- Scanning indicator -->
    <LinearLayout
        android:id="@+id/scanning_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/activity_background_basic"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/content_padding_half"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/scanning_progress"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/scanning_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/content_padding_half"
            android:text="@string/p2p_share_scanning"
            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
            android:textStyle="italic" />

    </LinearLayout>

    <!-- Nearby peers section header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingTop="@dimen/content_padding"
        android:paddingBottom="@dimen/content_padding_half"
        android:text="@string/p2p_share_nearby_devices"
        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
        android:textColor="?attr/default_icon_color" />

    <!-- Content area: peers list OR empty state (use FrameLayout to stack them) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Peers list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/peers_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/content_padding_half"
            android:visibility="gone" />

        <!-- Empty state for no peers -->
        <LinearLayout
            android:id="@+id/empty_peers_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/content_padding">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_action_wifi_off"
                android:tint="?attr/default_icon_color" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding"
                android:gravity="center"
                android:text="@string/p2p_share_no_devices"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/p2p_share_no_devices_desc"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

            <Button
                android:id="@+id/start_scan_button"
                style="@style/Widget.AppCompat.Button.Colored"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding"
                android:text="@string/p2p_share_scan" />

        </LinearLayout>

    </FrameLayout>

    <!-- Transfer Progress Card -->
    <LinearLayout
        android:id="@+id/transfer_progress_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_rounded"
        android:visibility="gone">

        <TextView
            android:id="@+id/transfer_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/lampp_text_body"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="middle" />

        <ProgressBar
            android:id="@+id/transfer_progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/transfer_progress_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/lampp_text_detail" />

            <Button
                android:id="@+id/transfer_cancel_button"
                style="@style/Widget.AppCompat.Button.Borderless.Colored"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shared_string_cancel"
                android:textSize="@dimen/lampp_text_detail"
                android:minHeight="0dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- My shared content section (fixed at bottom) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/divider_color" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/activity_background_basic"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/content_padding">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/p2p_share_my_content"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

            <TextView
                android:id="@+id/my_content_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/p2p_share_no_content"
                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                android:textColor="?attr/default_icon_color" />

        </LinearLayout>

        <Button
            android:id="@+id/configure_content_button"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shared_string_settings"
            android:textAllCaps="false" />

    </LinearLayout>

</LinearLayout>
