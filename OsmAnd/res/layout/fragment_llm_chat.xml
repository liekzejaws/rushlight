<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/list_background_color">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="?attr/app_bar_primary_item_color" />

    <!-- Phase 17: Model status bar - redesigned with distinct visual states -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/model_status_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/model_status_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <!-- Status icon or progress ring -->
            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp">

                <ImageView
                    android:id="@+id/model_status_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_action_info_outlined"
                    android:contentDescription="@string/model_status_icon_desc" />

                <ProgressBar
                    android:id="@+id/model_loading_progress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    android:contentDescription="@string/model_loading_desc" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/model_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No model installed"
                    android:textSize="@dimen/lampp_text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/model_status_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/lampp_text_detail"
                    android:visibility="gone" />
            </LinearLayout>

            <Button
                android:id="@+id/model_action_button"
                style="@style/Widget.AppCompat.Button.Borderless.Colored"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="@string/shared_string_download"
                android:textAllCaps="false"
                android:textSize="@dimen/lampp_text_button" />

        </LinearLayout>

        <!-- v0.5: Inline download progress bar (visible during model download) -->
        <ProgressBar
            android:id="@+id/model_download_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

    </com.google.android.material.card.MaterialCardView>

    <!-- v0.9: Crisis Mode banner — visible when active, tap to deactivate -->
    <LinearLayout
        android:id="@+id/crisis_mode_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CCFF2222"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_action_alert"
            android:tint="#FFFFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="CRISIS MODE — Fast terse responses"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAP TO DISABLE"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:alpha="0.8" />

    </LinearLayout>

    <!-- Chat messages area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/content_padding" />

    <!-- Phase 17: Empty state with suggestion chips -->
    <ScrollView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/content_padding"
            android:paddingTop="32dp"
            android:paddingBottom="@dimen/content_padding">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_action_help"
                android:tint="?attr/default_icon_color"
                android:alpha="0.6" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="AI Assistant"
                android:textSize="@dimen/lampp_text_title"
                android:textStyle="bold"
                android:textColor="?attr/main_font_color_basic" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="Try asking:"
                android:textSize="@dimen/lampp_text_caption"
                android:textColor="?attr/searchbar_text_hint" />

            <!-- Suggestion chips container (populated dynamically) -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/suggestion_chip_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingVertical="4dp"
                app:chipSpacingHorizontal="8dp"
                app:singleLine="false" />

        </LinearLayout>
    </ScrollView>

    <!-- Generating indicator -->
    <LinearLayout
        android:id="@+id/generating_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/content_padding_half"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/generating_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/content_padding_half"
            android:text="@string/rag_status_generating"
            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
            android:textStyle="italic" />

    </LinearLayout>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/activity_background_basic"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/content_padding_half">

        <EditText
            android:id="@+id/message_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_round_btn_light"
            android:hint="Type a message..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:padding="@dimen/content_padding"
            android:textColor="?attr/main_font_color_basic"
            android:textColorHint="?attr/searchbar_text_hint" />

        <ImageButton
            android:id="@+id/send_button"
            style="@style/Widget.AppCompat.ActionButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/content_padding_half"
            android:contentDescription="Send"
            android:enabled="false"
            app:srcCompat="@drawable/ic_action_gdirections_dark"
            app:tint="?attr/active_color_basic" />

    </LinearLayout>

</LinearLayout>
