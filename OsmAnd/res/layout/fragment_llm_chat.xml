<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/list_background_color">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="?attr/app_bar_primary_item_color" />

    <!-- Model status bar - entire bar is clickable -->
    <LinearLayout
        android:id="@+id/model_status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/content_padding_half">

        <ImageView
            android:id="@+id/model_status_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_action_info_outlined"
            android:tint="?attr/default_icon_color" />

        <TextView
            android:id="@+id/model_status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/content_padding_half"
            android:text="No model loaded"
            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
            android:textColor="?attr/default_icon_color" />

        <Button
            android:id="@+id/model_action_button"
            style="@style/Widget.AppCompat.Button.Borderless.Colored"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="@dimen/content_padding"
            android:paddingVertical="@dimen/content_padding_half"
            android:text="@string/shared_string_download"
            android:textAllCaps="false"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Chat messages area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/content_padding" />

    <!-- Empty state (no messages) -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/content_padding"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_action_help"
            android:tint="?attr/default_icon_color" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:gravity="center"
            android:text="AI Assistant"
            android:textAppearance="@style/TextAppearance.AppCompat.Headline" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Ask questions about survival, navigation, or any topic"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

    </LinearLayout>

    <!-- Generating indicator -->
    <LinearLayout
        android:id="@+id/generating_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/content_padding_half"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminate="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/content_padding_half"
            android:text="Generating response..."
            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
            android:textStyle="italic" />

    </LinearLayout>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/activity_background_basic"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/content_padding"
        android:paddingVertical="@dimen/content_padding_half">

        <EditText
            android:id="@+id/message_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_round_btn_light"
            android:hint="Type a message..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:padding="@dimen/content_padding"
            android:textColor="?attr/main_font_color_basic"
            android:textColorHint="?attr/searchbar_text_hint" />

        <ImageButton
            android:id="@+id/send_button"
            style="@style/Widget.AppCompat.ActionButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/content_padding_half"
            android:contentDescription="Send"
            android:enabled="false"
            app:srcCompat="@drawable/ic_action_gdirections_dark"
            app:tint="?attr/active_color_basic" />

    </LinearLayout>

</LinearLayout>
