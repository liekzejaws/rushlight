<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:padding="20dp"
	android:background="@color/lampp_bg_solid">

	<!-- Title -->
	<TextView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/demo_preflight_title"
		android:textSize="20sp"
		android:textStyle="bold"
		android:textColor="?attr/main_font_color_basic"
		android:layout_marginBottom="4dp" />

	<TextView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/demo_preflight_subtitle"
		android:textSize="13sp"
		android:textColor="@color/lampp_text_secondary"
		android:layout_marginBottom="16dp" />

	<!-- Check items list -->
	<LinearLayout
		android:id="@+id/checks_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:layout_marginBottom="16dp" />

	<!-- Status summary -->
	<TextView
		android:id="@+id/preflight_summary"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:textSize="14sp"
		android:textStyle="bold"
		android:gravity="center"
		android:layout_marginBottom="12dp" />

	<!-- Button row -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:gravity="end">

		<com.google.android.material.button.MaterialButton
			android:id="@+id/recheck_button"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/demo_preflight_recheck"
			android:textAllCaps="false"
			android:textSize="13sp"
			style="@style/Widget.MaterialComponents.Button.TextButton" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/start_demo_button"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginStart="8dp"
			android:text="@string/demo_preflight_start"
			android:textAllCaps="false"
			android:textSize="13sp"
			android:enabled="false"
			app:cornerRadius="8dp"
			style="@style/Widget.MaterialComponents.Button" />

	</LinearLayout>

</LinearLayout>
