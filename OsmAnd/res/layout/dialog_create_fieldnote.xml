<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add FieldNote"
            android:textSize="@dimen/lampp_text_header"
            android:textStyle="bold"
            android:textColor="?attr/main_font_color_basic" />

        <!-- Location display -->
        <TextView
            android:id="@+id/fieldnote_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="@dimen/lampp_text_detail"
            android:textColor="?attr/searchbar_text_hint" />

        <!-- Category picker -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Category"
            android:textSize="@dimen/lampp_text_caption"
            android:textStyle="bold"
            android:textColor="?attr/main_font_color_basic" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/category_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingVertical="4dp"
            app:chipSpacingHorizontal="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:singleLine="false" />

        <!-- Title input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Title (short label for map pin)"
            app:counterEnabled="true"
            app:counterMaxLength="50">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fieldnote_title_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLength="50"
                android:textSize="@dimen/lampp_text_body" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Note input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Note (details visible when tapped)"
            app:counterEnabled="true"
            app:counterMaxLength="500">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fieldnote_note_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLength="500"
                android:maxLines="5"
                android:minLines="3"
                android:textSize="@dimen/lampp_text_body" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- TTL picker -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Expires after"
            android:textSize="@dimen/lampp_text_caption"
            android:textStyle="bold"
            android:textColor="?attr/main_font_color_basic" />

        <Spinner
            android:id="@+id/fieldnote_ttl_spinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/fieldnote_cancel_button"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/fieldnote_save_button"
                style="@style/Widget.AppCompat.Button.Colored"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Save"
                android:textAllCaps="false"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
