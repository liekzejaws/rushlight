<?xml version="1.0" encoding="utf-8"?>
<!-- Multi-step onboarding overlay for Rushlight -->
<FrameLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:id="@+id/onboarding_root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#CC000000"
	android:clickable="true"
	android:focusable="true">

	<!-- Center content: Step-based onboarding -->
	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_gravity="center"
		android:orientation="vertical"
		android:paddingStart="32dp"
		android:paddingEnd="32dp"
		android:paddingTop="24dp"
		android:paddingBottom="24dp"
		android:gravity="center_horizontal">

		<!-- Step icon -->
		<ImageView
			android:id="@+id/onboarding_icon"
			android:layout_width="64dp"
			android:layout_height="64dp"
			android:layout_marginBottom="16dp"
			android:src="@drawable/ic_action_world_globe"
			android:contentDescription="Step icon" />

		<!-- Step title -->
		<TextView
			android:id="@+id/onboarding_title"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/onboarding_title"
			android:textColor="@android:color/white"
			android:textSize="24sp"
			android:textStyle="bold"
			android:layout_marginBottom="8dp" />

		<!-- Step description (replaces subtitle + tab list) -->
		<TextView
			android:id="@+id/onboarding_description"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/onboarding_subtitle"
			android:textColor="#CCFFFFFF"
			android:textSize="15sp"
			android:lineSpacingExtra="3dp"
			android:layout_marginBottom="24dp"
			android:maxWidth="320dp"
			android:gravity="center" />

		<!-- Action button (Next / Get Started / Start Exploring) -->
		<Button
			android:id="@+id/onboarding_dismiss"
			android:layout_width="wrap_content"
			android:layout_height="44dp"
			android:minWidth="160dp"
			android:text="@string/onboarding_got_it"
			android:textColor="#FF000000"
			android:backgroundTint="#FF4CAF50"
			android:textStyle="bold"
			android:layout_marginBottom="16dp" />

		<!-- Skip button (text link style) -->
		<TextView
			android:id="@+id/onboarding_skip"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Skip"
			android:textColor="#88FFFFFF"
			android:textSize="14sp"
			android:padding="8dp"
			android:layout_marginBottom="16dp" />

		<!-- Progress dots container -->
		<LinearLayout
			android:id="@+id/onboarding_dots"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center" />

	</LinearLayout>

</FrameLayout>
