<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:background="?attr/list_background_color"
	android:padding="24dp"
	android:gravity="center_horizontal">

	<!-- Title -->
	<TextView
		android:id="@+id/pin_title"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/enter_pin"
		android:textSize="20sp"
		android:textStyle="bold"
		android:textColor="?attr/main_font_color_basic"
		android:layout_marginBottom="8dp" />

	<!-- Status / Error text -->
	<TextView
		android:id="@+id/pin_status"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:textSize="14sp"
		android:textColor="@color/color_warning"
		android:visibility="gone"
		android:layout_marginBottom="16dp" />

	<!-- PIN dot indicators -->
	<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:gravity="center"
		android:layout_marginBottom="24dp">

		<ImageView
			android:id="@+id/pin_dot_1"
			android:layout_width="16dp"
			android:layout_height="16dp"
			android:layout_marginHorizontal="8dp"
			android:src="@drawable/ic_dot_position"
			android:tint="@color/lampp_text_secondary" />

		<ImageView
			android:id="@+id/pin_dot_2"
			android:layout_width="16dp"
			android:layout_height="16dp"
			android:layout_marginHorizontal="8dp"
			android:src="@drawable/ic_dot_position"
			android:tint="@color/lampp_text_secondary" />

		<ImageView
			android:id="@+id/pin_dot_3"
			android:layout_width="16dp"
			android:layout_height="16dp"
			android:layout_marginHorizontal="8dp"
			android:src="@drawable/ic_dot_position"
			android:tint="@color/lampp_text_secondary" />

		<ImageView
			android:id="@+id/pin_dot_4"
			android:layout_width="16dp"
			android:layout_height="16dp"
			android:layout_marginHorizontal="8dp"
			android:src="@drawable/ic_dot_position"
			android:tint="@color/lampp_text_secondary" />
	</LinearLayout>

	<!-- Numeric keypad: 3x4 grid -->
	<GridLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:columnCount="3"
		android:rowCount="4"
		android:alignmentMode="alignBounds">

		<!-- Row 1: 1, 2, 3 -->
		<Button android:id="@+id/key_1" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="1" android:textSize="24sp" />
		<Button android:id="@+id/key_2" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="2" android:textSize="24sp" />
		<Button android:id="@+id/key_3" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="3" android:textSize="24sp" />

		<!-- Row 2: 4, 5, 6 -->
		<Button android:id="@+id/key_4" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="4" android:textSize="24sp" />
		<Button android:id="@+id/key_5" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="5" android:textSize="24sp" />
		<Button android:id="@+id/key_6" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="6" android:textSize="24sp" />

		<!-- Row 3: 7, 8, 9 -->
		<Button android:id="@+id/key_7" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="7" android:textSize="24sp" />
		<Button android:id="@+id/key_8" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="8" android:textSize="24sp" />
		<Button android:id="@+id/key_9" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="9" android:textSize="24sp" />

		<!-- Row 4: Cancel, 0, Backspace -->
		<Button android:id="@+id/key_cancel" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="@string/shared_string_cancel" android:textSize="12sp" />
		<Button android:id="@+id/key_0" style="@style/Widget.AppCompat.Button.Borderless"
			android:layout_width="72dp" android:layout_height="56dp"
			android:text="0" android:textSize="24sp" />
		<ImageButton android:id="@+id/key_backspace"
			style="@style/Widget.AppCompat.ActionButton"
			android:layout_width="72dp" android:layout_height="56dp"
			android:src="@drawable/ic_action_undo_dark"
			android:contentDescription="@string/shared_string_delete"
			android:layout_gravity="center" />
	</GridLayout>

</LinearLayout>
