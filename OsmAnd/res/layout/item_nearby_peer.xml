<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/content_padding_half"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="?attr/card_and_list_background_basic"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/content_padding">

        <!-- Device icon -->
        <ImageView
            android:id="@+id/peer_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_action_device_top"
            android:tint="?attr/active_color_basic" />

        <!-- Device info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/content_padding"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/peer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Device Name"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textColor="?attr/main_font_color_basic" />

            <TextView
                android:id="@+id/peer_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="3 maps, 1 model"
                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                android:textColor="?attr/default_icon_color" />

        </LinearLayout>

        <!-- Distance indicator -->
        <TextView
            android:id="@+id/peer_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nearby"
            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
            android:textColor="?attr/default_icon_color" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
