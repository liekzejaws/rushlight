<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/list_background_color">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/shared_string_wikipedia"
        app:titleTextColor="?attr/app_bar_primary_item_color" />

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:tabIndicatorColor="?attr/app_bar_primary_item_color"
        app:tabSelectedTextColor="?attr/app_bar_primary_item_color"
        app:tabTextColor="?attr/text_color_tab_active_white">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shared_string_local" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/shared_string_download" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- LOCAL TAB CONTENT -->
        <ScrollView
            android:id="@+id/local_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Downloaded Files Section Header -->
                <TextView
                    android:id="@+id/downloaded_files_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/content_padding"
                    android:paddingTop="@dimen/content_padding"
                    android:paddingBottom="@dimen/content_padding_half"
                    android:text="@string/downloaded_files"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                    android:textColor="?attr/active_color_basic"
                    android:visibility="gone" />

                <!-- Downloaded Files List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/downloaded_files_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <!-- Divider between downloaded files and current ZIM -->
                <View
                    android:id="@+id/downloaded_files_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="@dimen/content_padding"
                    android:layout_marginVertical="@dimen/content_padding_half"
                    android:background="?attr/divider_color"
                    android:visibility="gone" />

                <!-- ZIM File Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/zim_info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/content_padding"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/content_padding">

                    <TextView
                        android:id="@+id/zim_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/zim_article_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.AppCompat.Caption" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Search Container -->
            <LinearLayout
                android:id="@+id/search_container"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="@dimen/content_padding"
                android:layout_marginTop="@dimen/content_padding_half"
                android:background="?attr/activity_background_basic"
                android:focusableInTouchMode="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/content_padding"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_action_search_dark"
                    android:contentDescription="@string/shared_string_search" />

                <EditText
                    android:id="@+id/search_edit_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/content_padding"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:hint="@string/search_poi_filter"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:lines="1"
                    android:singleLine="true"
                    android:textColor="?attr/searchbar_text"
                    android:textColorHint="?attr/searchbar_text_hint" />

                <ProgressBar
                    android:id="@+id/search_progress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/clear_button"
                    style="@style/Widget.AppCompat.ActionButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/shared_string_clear"
                    android:visibility="gone"
                    app:srcCompat="@drawable/ic_action_remove_dark" />

            </LinearLayout>

            <!-- Search Status Text -->
            <TextView
                android:id="@+id/search_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingVertical="@dimen/content_padding_half"
                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                android:textColor="?attr/default_icon_color"
                android:visibility="gone" />

            <!-- Search Results -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/search_results"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

            <!-- Local Empty State -->
            <LinearLayout
                android:id="@+id/local_empty_state"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/content_padding">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_action_read_from_file"
                    android:tint="?attr/default_icon_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_padding"
                    android:gravity="center"
                    android:text="@string/no_file_selected"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/zim_smart_acquire_desc"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                <Button
                    android:id="@+id/open_zim_button"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_padding"
                    android:text="@string/find_wikipedia" />

            </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- DOWNLOAD TAB CONTENT -->
        <LinearLayout
            android:id="@+id/download_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Language Filter -->
            <LinearLayout
                android:id="@+id/language_filter_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingVertical="@dimen/content_padding_half"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shared_string_language"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                <Spinner
                    android:id="@+id/language_spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/content_padding" />

            </LinearLayout>

            <!-- Catalog List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/catalog_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/catalog_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/content_padding"
                android:visibility="gone" />

            <!-- Download Empty State -->
            <LinearLayout
                android:id="@+id/download_empty_state"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/content_padding">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_action_import"
                    android:tint="?attr/default_icon_color" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_padding"
                    android:gravity="center"
                    android:text="@string/catalog_load_error"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/try_again_later"
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1" />

                <Button
                    android:id="@+id/refresh_catalog_button"
                    style="@style/Widget.AppCompat.Button.Colored"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_padding"
                    android:text="@string/shared_string_refresh" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
