<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:layout_marginBottom="6dp"
	android:clickable="true"
	android:focusable="true"
	app:cardBackgroundColor="@color/lampp_bg_solid"
	app:cardCornerRadius="8dp"
	app:cardElevation="1dp">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:padding="12dp"
		android:gravity="center_vertical">

		<!-- Importance indicator strip -->
		<View
			android:id="@+id/importance_strip"
			android:layout_width="4dp"
			android:layout_height="40dp"
			android:layout_marginEnd="12dp"
			android:background="#FF4444" />

		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:orientation="vertical">

			<TextView
				android:id="@+id/guide_title"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="@dimen/lampp_text_body"
				android:textStyle="bold"
				android:textColor="?attr/main_font_color_basic"
				android:maxLines="2"
				android:ellipsize="end" />

			<TextView
				android:id="@+id/guide_summary"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="@dimen/lampp_text_detail"
				android:textColor="?attr/searchbar_text_hint"
				android:maxLines="2"
				android:ellipsize="end"
				android:layout_marginTop="2dp" />

		</LinearLayout>

		<ImageView
			android:layout_width="20dp"
			android:layout_height="20dp"
			android:layout_marginStart="8dp"
			android:src="@drawable/ic_action_arrow_forward_16"
			app:tint="?attr/lampp_button_text" />

	</LinearLayout>
</com.google.android.material.card.MaterialCardView>
