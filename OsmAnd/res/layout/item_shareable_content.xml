<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/content_padding"
    android:paddingVertical="@dimen/content_padding_half">

    <!-- Content type icon -->
    <ImageView
        android:id="@+id/content_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_world_globe_dark"
        android:tint="?attr/default_icon_color"
        tools:ignore="ContentDescription" />

    <!-- Content info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/content_padding"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/content_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textColor="?attr/main_font_color_basic"
            tools:text="Ohio.obf" />

        <TextView
            android:id="@+id/content_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
            android:textColor="?attr/default_icon_color"
            tools:text="456 MB · Map" />

    </LinearLayout>

    <!-- Checkbox -->
    <androidx.appcompat.widget.AppCompatCheckBox
        android:id="@+id/content_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="false"
        android:focusable="false" />

</LinearLayout>
