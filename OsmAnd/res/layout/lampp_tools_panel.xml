<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fillViewport="true">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="16dp">

		<!-- Section header -->
		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Theme"
			android:textSize="@dimen/lampp_text_header"
			android:textStyle="bold"
			android:textColor="?attr/main_font_color_basic"
			android:layout_marginBottom="12dp" />

		<!-- Pip-Boy preset card -->
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/preset_pip_boy"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			app:cardBackgroundColor="@color/lampp_bg_solid"
			app:cardCornerRadius="12dp"
			app:cardElevation="2dp"
			app:strokeColor="@color/lampp_green_primary"
			app:strokeWidth="2dp">

			<RelativeLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="16dp">

				<!-- Color preview stripe -->
				<View
					android:id="@+id/stripe_pip_boy"
					android:layout_width="4dp"
					android:layout_height="40dp"
					android:layout_alignParentStart="true"
					android:layout_centerVertical="true"
					android:background="@color/lampp_green_primary"
					android:importantForAccessibility="no" />

				<LinearLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_toEndOf="@id/stripe_pip_boy"
					android:layout_marginStart="12dp"
					android:layout_centerVertical="true"
					android:orientation="vertical">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Pip-Boy"
						android:textSize="@dimen/lampp_text_subheader"
						android:textStyle="bold"
						android:textColor="@color/lampp_green_primary" />

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Retro-futuristic terminal"
						android:textSize="@dimen/lampp_text_caption"
			android:textAllCaps="false"
						android:textColor="@color/lampp_text_secondary" />

				</LinearLayout>

				<ImageView
					android:id="@+id/check_pip_boy"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:layout_alignParentEnd="true"
					android:layout_centerVertical="true"
					android:src="@drawable/ic_action_done"
					android:visibility="gone"
					android:contentDescription="@string/theme_selection_check_desc"
					app:tint="@color/lampp_green_primary" />

			</RelativeLayout>
		</com.google.android.material.card.MaterialCardView>

		<!-- Modern preset card -->
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/preset_modern"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			app:cardBackgroundColor="@color/lampp_modern_list_bg"
			app:cardCornerRadius="12dp"
			app:cardElevation="2dp"
			app:strokeColor="@color/lampp_modern_primary"
			app:strokeWidth="2dp">

			<RelativeLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="16dp">

				<View
					android:id="@+id/stripe_modern"
					android:layout_width="4dp"
					android:layout_height="40dp"
					android:layout_alignParentStart="true"
					android:layout_centerVertical="true"
					android:background="@color/lampp_modern_primary"
					android:importantForAccessibility="no" />

				<LinearLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_toEndOf="@id/stripe_modern"
					android:layout_marginStart="12dp"
					android:layout_centerVertical="true"
					android:orientation="vertical">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Modern"
						android:textSize="@dimen/lampp_text_subheader"
						android:textStyle="bold"
						android:textColor="@color/lampp_modern_text_primary" />

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Sleek teal and grey"
						android:textSize="@dimen/lampp_text_caption"
			android:textAllCaps="false"
						android:textColor="@color/lampp_modern_text_secondary" />

				</LinearLayout>

				<ImageView
					android:id="@+id/check_modern"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:layout_alignParentEnd="true"
					android:layout_centerVertical="true"
					android:src="@drawable/ic_action_done"
					android:visibility="gone"
					android:contentDescription="@string/theme_selection_check_desc"
					app:tint="@color/lampp_modern_primary" />

			</RelativeLayout>
		</com.google.android.material.card.MaterialCardView>

		<!-- Classic OsmAnd preset card -->
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/preset_classic"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:clickable="true"
			android:focusable="true"
			app:cardBackgroundColor="@color/lampp_classic_card_preview_bg"
			app:cardCornerRadius="12dp"
			app:cardElevation="2dp"
			app:strokeColor="@color/lampp_classic_tab_active_light"
			app:strokeWidth="2dp">

			<RelativeLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="16dp">

				<View
					android:id="@+id/stripe_classic"
					android:layout_width="4dp"
					android:layout_height="40dp"
					android:layout_alignParentStart="true"
					android:layout_centerVertical="true"
					android:background="@color/lampp_classic_tab_active_light"
					android:importantForAccessibility="no" />

				<LinearLayout
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_toEndOf="@id/stripe_classic"
					android:layout_marginStart="12dp"
					android:layout_centerVertical="true"
					android:orientation="vertical">

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Classic OsmAnd"
						android:textSize="@dimen/lampp_text_subheader"
						android:textStyle="bold"
						android:textColor="@color/lampp_classic_text_primary_light" />

					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Default OsmAnd look"
						android:textSize="@dimen/lampp_text_caption"
			android:textAllCaps="false"
						android:textColor="@color/lampp_classic_text_secondary_light" />

				</LinearLayout>

				<ImageView
					android:id="@+id/check_classic"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:layout_alignParentEnd="true"
					android:layout_centerVertical="true"
					android:src="@drawable/ic_action_done"
					android:visibility="gone"
					android:contentDescription="@string/theme_selection_check_desc"
					app:tint="@color/lampp_classic_tab_active_light" />

			</RelativeLayout>
		</com.google.android.material.card.MaterialCardView>

		<!-- Divider -->
		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?attr/divider_color"
			android:layout_marginBottom="12dp" />

		<!-- More settings button -->
		<com.google.android.material.button.MaterialButton
			android:id="@+id/more_settings_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="More settings..."
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_settings"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- Show Setup Guide button -->
		<com.google.android.material.button.MaterialButton
			android:id="@+id/show_setup_guide_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="8dp"
			android:text="Show Setup Guide"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_help"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- v0.8: Run Benchmark button -->
		<com.google.android.material.button.MaterialButton
			android:id="@+id/run_benchmark_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:text="Run Benchmark"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_time_span"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- v1.4: Device Report button -->
		<com.google.android.material.button.MaterialButton
			android:id="@+id/device_report_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:text="Device Report"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_info_dark"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- v1.0: FieldNotes section -->
		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?attr/divider_color"
			android:layout_marginTop="12dp"
			android:layout_marginBottom="12dp" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="FieldNotes"
			android:textSize="@dimen/lampp_text_subheader"
			android:textStyle="bold"
			android:textColor="?attr/main_font_color_basic"
			android:layout_marginBottom="4dp" />

		<TextView
			android:id="@+id/fieldnotes_count_text"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="No notes"
			android:textSize="@dimen/lampp_text_caption"
			android:textAllCaps="false"
			android:textColor="?attr/searchbar_text_hint"
			android:layout_marginBottom="8dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/fieldnotes_list_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="4dp"
			android:text="View All FieldNotes"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_flag"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/fieldnotes_cleanup_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="4dp"
			android:text="Clean Up Expired"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_delete_dark"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- Prepare Demo button -->
		<com.google.android.material.button.MaterialButton
			android:id="@+id/prepare_demo_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:text="Prepare Demo"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_start_navigation"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- Divider -->
		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?attr/divider_color"
			android:layout_marginTop="12dp"
			android:layout_marginBottom="12dp" />

		<!-- Security section -->
		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/rushlight_security_title"
			android:textSize="@dimen/lampp_text_header"
			android:textStyle="bold"
			android:textColor="?attr/main_font_color_basic"
			android:layout_marginBottom="12dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/panic_wipe_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/rushlight_panic_wipe"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="@android:color/white"
			android:backgroundTint="@color/lampp_accent_red"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_delete_dark"
			app:iconTint="@android:color/white"
			style="@style/Widget.MaterialComponents.Button" />

		<!-- Phase 15: Security PIN section -->
		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?attr/divider_color"
			android:layout_marginTop="12dp"
			android:layout_marginBottom="12dp" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/security_pin_section"
			android:textSize="@dimen/lampp_text_subheader"
			android:textStyle="bold"
			android:textColor="?attr/main_font_color_basic"
			android:layout_marginBottom="8dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/set_real_pin_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="4dp"
			android:text="@string/set_unlock_pin"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_lock"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/set_duress_pin_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="4dp"
			android:text="@string/set_duress_pin"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="@color/lampp_accent_red"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			android:visibility="gone"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_delete_dark"
			app:iconTint="@color/lampp_accent_red"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center_vertical"
			android:layout_marginBottom="4dp">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/duress_wipe_scope"
				android:textSize="@dimen/lampp_text_body"
				android:textColor="?attr/searchbar_text_hint"
				android:layout_marginEnd="8dp" />

			<TextView
				android:id="@+id/wipe_scope_text"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="@string/wipe_chat_only"
				android:textSize="@dimen/lampp_text_body"
				android:textStyle="bold"
				android:textColor="?attr/main_font_color_basic"
				android:background="?attr/selectableItemBackground"
				android:padding="4dp" />
		</LinearLayout>

		<com.google.android.material.button.MaterialButton
			android:id="@+id/clear_pins_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/clear_pins"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			android:visibility="gone"
			app:cornerRadius="8dp"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

		<!-- Phase 15 Session 2: Stealth Mode section -->
		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?attr/divider_color"
			android:layout_marginTop="12dp"
			android:layout_marginBottom="12dp" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/stealth_mode"
			android:textSize="@dimen/lampp_text_subheader"
			android:textStyle="bold"
			android:textColor="?attr/main_font_color_basic"
			android:layout_marginBottom="4dp" />

		<TextView
			android:id="@+id/stealth_status_indicator"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/stealth_inactive"
			android:textSize="@dimen/lampp_text_caption"
			android:textAllCaps="false"
			android:textColor="?attr/searchbar_text_hint"
			android:layout_marginBottom="8dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/stealth_settings_button"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/stealth_settings"
			android:textSize="@dimen/lampp_text_button"
			android:textAllCaps="false"
			android:textColor="?attr/lampp_button_text"
			android:backgroundTint="@color/lampp_btn_tint_transparent_white"
			app:cornerRadius="8dp"
			app:icon="@drawable/ic_action_hide"
			app:iconTint="?attr/lampp_button_text"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

	</LinearLayout>
</ScrollView>
