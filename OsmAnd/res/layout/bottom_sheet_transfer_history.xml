<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="?attr/list_background_color"
	android:orientation="vertical">

	<!-- Header with title, clear, and close buttons -->
	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:paddingHorizontal="@dimen/content_padding"
		android:paddingVertical="@dimen/content_padding">

		<TextView
			android:id="@+id/title_text"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:text="@string/p2p_share_transfer_history"
			android:textAppearance="@style/TextAppearance.AppCompat.Title" />

		<ImageButton
			android:id="@+id/clear_button"
			style="@style/Widget.AppCompat.ActionButton"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:contentDescription="@string/shared_string_clear_all"
			app:srcCompat="@drawable/ic_action_delete_dark"
			app:tint="?attr/default_icon_color" />

		<ImageButton
			android:id="@+id/close_button"
			style="@style/Widget.AppCompat.ActionButton"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:contentDescription="@string/shared_string_close"
			app:srcCompat="@drawable/ic_action_close"
			app:tint="?attr/default_icon_color" />

	</LinearLayout>

	<!-- Divider -->
	<View
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:background="?attr/divider_color" />

	<!-- Empty state -->
	<TextView
		android:id="@+id/empty_state"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center"
		android:padding="@dimen/content_padding"
		android:text="@string/p2p_share_no_history"
		android:textAppearance="@style/TextAppearance.AppCompat.Body1"
		android:textColor="?attr/default_icon_color"
		android:visibility="gone" />

	<!-- History list -->
	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/history_recycler"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:clipToPadding="false"
		android:paddingBottom="@dimen/content_padding" />

	<!-- Bottom summary -->
	<View
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:background="?attr/divider_color" />

	<TextView
		android:id="@+id/summary_text"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="?attr/activity_background_basic"
		android:gravity="center"
		android:padding="@dimen/content_padding"
		android:textAppearance="@style/TextAppearance.AppCompat.Caption"
		android:textColor="?attr/default_icon_color" />

</LinearLayout>
