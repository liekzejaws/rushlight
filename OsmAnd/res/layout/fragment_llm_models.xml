<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/list_background_color">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="?attr/app_bar_primary_item_color" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/content_padding"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/content_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="About AI Models"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="AI models (GGUF format) run entirely on your device for offline use. Supports Deepseek, Phi, Qwen, Llama, Mistral, etc. Requires 4-8 GB RAM depending on model size."
                        android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Downloaded Models Section -->
            <TextView
                android:id="@+id/downloaded_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingTop="@dimen/content_padding"
                android:paddingBottom="@dimen/content_padding_half"
                android:text="Downloaded Models"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?attr/active_color_basic" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/downloaded_models_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- No downloaded models message -->
            <TextView
                android:id="@+id/no_downloaded_models"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/content_padding"
                android:text="No models downloaded yet"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?attr/default_icon_color"
                android:visibility="gone" />

            <!-- Available Models Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/content_padding"
                android:paddingTop="@dimen/content_padding"
                android:paddingBottom="@dimen/content_padding_half"
                android:text="Available Models"
                android:textAppearance="@style/TextAppearance.AppCompat.Body2"
                android:textColor="?attr/active_color_basic" />

            <!-- TinyLlama Model Card - smallest for testing -->
            <androidx.cardview.widget.CardView
                android:id="@+id/gemma_2b_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/content_padding"
                android:layout_marginVertical="@dimen/content_padding_half"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/content_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="TinyLlama 1.1B"
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Smallest model. Good for testing and low-end devices. GGUF format."
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~669 MB"
                            android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                            android:textColor="?attr/default_icon_color" />

                    </LinearLayout>

                    <!-- Download progress -->
                    <ProgressBar
                        android:id="@+id/gemma_2b_progress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding_half"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/gemma_2b_progress_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/gemma_2b_button"
                        style="@style/Widget.AppCompat.Button.Colored"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding_half"
                        android:text="@string/shared_string_download" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Storage Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/content_padding">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_action_storage"
                    android:tint="?attr/default_icon_color" />

                <TextView
                    android:id="@+id/storage_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/content_padding_half"
                    android:text="Storage used: 0 MB"
                    android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                    android:textColor="?attr/default_icon_color" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
