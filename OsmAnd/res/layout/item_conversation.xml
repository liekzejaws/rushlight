<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="horizontal"
	android:gravity="center_vertical"
	android:paddingHorizontal="16dp"
	android:paddingVertical="12dp"
	android:background="?attr/selectableItemBackground"
	android:clickable="true"
	android:focusable="true">

	<!-- Conversation icon -->
	<ImageView
		android:id="@+id/conv_icon"
		android:layout_width="32dp"
		android:layout_height="32dp"
		android:src="@drawable/ic_action_message"
		android:tint="?attr/default_icon_color" />

	<!-- Title and info -->
	<LinearLayout
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_weight="1"
		android:layout_marginStart="12dp"
		android:orientation="vertical">

		<TextView
			android:id="@+id/conv_title"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:textSize="15sp"
			android:textColor="?attr/main_font_color_basic"
			android:maxLines="1"
			android:ellipsize="end" />

		<TextView
			android:id="@+id/conv_info"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:textSize="12sp"
			android:textColor="@color/lampp_text_secondary"
			android:layout_marginTop="2dp" />
	</LinearLayout>

	<!-- Active indicator -->
	<ImageView
		android:id="@+id/conv_active_indicator"
		android:layout_width="20dp"
		android:layout_height="20dp"
		android:src="@drawable/ic_action_done"
		android:tint="?attr/active_color_basic"
		android:visibility="gone" />

	<!-- Delete button -->
	<ImageButton
		android:id="@+id/conv_delete"
		style="@style/Widget.AppCompat.ActionButton"
		android:layout_width="36dp"
		android:layout_height="36dp"
		android:contentDescription="@string/shared_string_delete"
		android:src="@drawable/ic_action_delete_dark"
		android:tint="@color/lampp_text_secondary"
		android:layout_marginStart="4dp" />

</LinearLayout>
